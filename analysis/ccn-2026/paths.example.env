# CCN 2026 — path template (used by notebooks)
#
# Copy this to `paths.local.env` (and `source` it) OR export variables in your shell.
# The notebooks currently reference these paths in-code for the defaults shown below.

# BV crops (used for montage/Plot A; also referenced in embedding workflows)
export BV_CROPS_BASE="path/to/babyview/outputs/yoloe_cdi_all_cropped_by_class"

# BV embeddings base (CLIP and DINOv3 embedding storage under this folder)
export BV_EMBEDDINGS_BASE="path/to/babyview/outputs/yoloe_cdi_embeddings"

# BV CLIP filter list (must match embedding/filter threshold used in notebooks; default in README is 0.27)
export BV_CLIP_FILTER_LIST="${BV_EMBEDDINGS_BASE}/clip_image_embeddings_filtered_all_frames_exclude-people_exclude-subject-00270001.csv"

# BV embedding subdirs
export BV_CLIP_EMBEDDINGS_DIR="${BV_EMBEDDINGS_BASE}/clip_embeddings_new"
export BV_DINOV3_EMBEDDINGS_DIR="${BV_EMBEDDINGS_BASE}/facebook_dinov3-vitb16-pretrain-lvd1689m"

# THINGS embedding sources (used by `analysis/ccn-2026/load_things_embeddings.py`)
# DinoV3:
export THINGS_DINOV3_DIR="path/to/things/image_embeddings/things_bv_overlapping_categories_corrected/facebook_dinov3-vitb16-pretrain-lvd1689m"

# THINGS CLIP:
# - one default uses a .docs store (EmbeddingStore)
# - the loader also tries to find a by-category .npy directory candidate if present
export THINGS_CLIP_DOCS="path/to/things/embeddings/image_embeddings/clip_image_embeddings_doc_normalized_filtered-by-clip-0.27.docs"

# Optional: point at the by-category .npy npy candidates (if available in your environment)
export THINGS_CLIP_NPY_CANDIDATE_1="path/to/things/clip_embeddings"
export THINGS_CLIP_NPY_CANDIDATE_2="path/to/things/clip_image_embeddings_npy_by_category"

