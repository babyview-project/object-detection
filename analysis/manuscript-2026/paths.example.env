# Copy to paths.local.env (gitignored) and adjust for your machine.
# Sourced by notebooks/scripts that read BV_* variables.

# Parent directory for flat per-crop embedding trees (CLIP / DINOv3 / BabyDINOv3)
BV_EMBEDDINGS_BASE=/data2/dataset/babyview/868_hours/outputs/yoloe_cdi_embeddings

# Flat per-image roots (do not use age-grouped subfolders)
BV_CLIP_EMBEDDINGS_DIR=${BV_EMBEDDINGS_BASE}/clip_embeddings_new
BV_DINOV3_EMBEDDINGS_DIR=${BV_EMBEDDINGS_BASE}/facebook_dinov3-vitb16-pretrain-lvd1689m
BV_BABYDINOV3_EMBEDDINGS_DIR=${BV_EMBEDDINGS_BASE}/babydinov3_grad_accum_1/step_119999
BV_BABYDINOV3_CHECKPOINT_STEP=119999

# CLIP similarity filter list (one absolute path per retained crop .npy)
BV_CLIP_FILTER_LIST_THRESHOLD=0.27
BV_CLIP_FILTER_LIST=${BV_EMBEDDINGS_BASE}/clip_image_embeddings_filtered-by-clip-0.27_exclude-people_exclude-subject-00270001.txt

# THINGS BabyDINOv3 outputs (create with create_babydinov3_things_embeddings.py)
THINGS_BABYDINOV3_EMBED_OUT=${BV_EMBEDDINGS_BASE}/things_babydinov3_grad_accum_1/step_119999

# Analysis toggles
CATEGORY_SET=valid129
BV_EMBED_MODEL=clip
TOP8_CATEGORY_SET=valid85
